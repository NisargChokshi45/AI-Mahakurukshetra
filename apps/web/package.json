{
  "name": "@repo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -ac 'set -a; [ -f ../../.env ] && . ../../.env; set +a; exec next dev'",
    "build": "sh -ac 'set -a; [ -f ../../.env ] && . ../../.env; set +a; exec next build --webpack'",
    "start": "sh -ac 'set -a; [ -f ../../.env ] && . ../../.env; set +a; exec next start'",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "check-types": "pnpm typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch --passWithNoTests",
    "test:e2e": "playwright test --config ../../playwright.config.ts --pass-with-no-tests",
    "verify:rls": "sh -ac 'set -a; [ -f ../../.env ] && . ../../.env; set +a; exec node --experimental-strip-types scripts/verify-rls-org-isolation.ts'",
    "validate:domains": "sh -ac 'set -a; [ -f ../../.env ] && . ../../.env; set +a; exec node scripts/validate-domain-config.mjs'",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../../.prettierignore --check ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.77.0",
    "@tanstack/react-query": "^5.90.5",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.7",
    "@upstash/redis": "^1.35.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-list": "^2.4.1",
    "country-state-city": "^3.2.1",
    "leaflet": "^1.9.4",
    "llm-info": "^1.0.69",
    "lucide-react": "^0.542.0",
    "next": "16.1.6",
    "pino": "^9.11.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.62.0",
    "react-leaflet": "^5.0.0",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "use-memo-one": "^1.1.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.1",
    "supabase": "^2.78.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
