{
  "name": "ai-mahakurukshetra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @repo/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "check-types": "pnpm typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "prepare": "husky",
    "db:push": "./scripts/migrate.sh push",
    "db:seed": "./scripts/seed-database.sh",
    "db:new": "./scripts/migrate.sh new",
    "db:status": "./scripts/migrate.sh status",
    "db:test": "./scripts/migrate.sh test",
    "db:pull": "./scripts/migrate.sh pull"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "latest",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{css,json,md,mjs,ts,tsx,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.26.2"
}
